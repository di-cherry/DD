<Page x:Class="DD.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Корзина">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView x:Name="CartListView"
                  Grid.Row="0"
                  HorizontalContentAlignment="Stretch">

            <ListView.View>
                <GridView>

                    <GridViewColumn Header="Название"
                                    DisplayMemberBinding="{Binding Name}" />

                    <GridViewColumn Header="Цена"
                                    DisplayMemberBinding="{Binding Price}" />

                    <GridViewColumn Header="Скидка %"
                                    DisplayMemberBinding="{Binding Discount}" />

                </GridView>
            </ListView.View>

        </ListView>

        <StackPanel Grid.Row="1"
                    Orientation="Vertical"
                    Margin="5">

            <TextBlock Text="Адрес доставки"/>

            <TextBox x:Name="AddressTxt"
                     Margin="0,5,0,5"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Удалить из корзины"
                        Margin="5"
                        Click="Remove_Click"/>

                <Button Content="Оформить заказ"
                        Margin="5"
                        Click="Order_Click"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</Page>
