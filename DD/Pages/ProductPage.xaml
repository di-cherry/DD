<Page x:Class="DD.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Продукция"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchTxtBx"
                     Margin="5"
                     TextChanged="Update"/>

            <ComboBox x:Name="SortCmbBx"
                      Grid.Column="1"
                      Margin="5"
                      SelectedIndex="0"
                      SelectionChanged="Update">
                <ComboBoxItem Content="Без сортировки"/>
                <ComboBoxItem Content="Цена ↑"/>
                <ComboBoxItem Content="Цена ↓"/>
            </ComboBox>

            <ComboBox x:Name="FiltrCmbBx"
                      Grid.Column="2"
                      Margin="5"
                      SelectionChanged="Update"/>
        </Grid>

        <ListBox x:Name="ProductListBox"
                 Grid.Row="1"
                 HorizontalContentAlignment="Stretch">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock FontWeight="Bold"
                                           Text="{Binding Name}"/>

                                <TextBlock Text="{Binding Category.Name}"/>

                                <TextBlock Text="{Binding Description}"/>

                                <TextBlock Text="{Binding Quantity, StringFormat=В наличии: {0}}"/>

                                <TextBlock Text="{Binding Discount, StringFormat=Скидка: {0}%}"/>

                            </StackPanel>

                            <StackPanel Grid.Column="1">

                                <TextBlock Text="{Binding Price, StringFormat={}{0} руб.}"
                                           Margin="5"
                                           HorizontalAlignment="Right"/>

                                <Button Content="В корзину"
                                        Margin="5"
                                        Tag="{Binding}"
                                        Click="AddToCart_Click"/>

                            </StackPanel>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDiscount}" Value="True">
                            <Setter Property="Background" Value="#BB5FCA"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>

        </ListBox>

        <StackPanel x:Name="AdminStPanl"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Grid.Row="2">

            <Button Content="Добавить"
                    Margin="5"
                    Click="AddProduct_Click"/>

            <Button Content="Изменить"
                    Margin="5"
                    Click="RedProduct_Click"/>

            <Button Content="Удалить"
                    Margin="5"
                    Click="DelProduct_Click"/>

        </StackPanel>

    </Grid>
</Page>