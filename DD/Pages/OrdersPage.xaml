<Page x:Class="DD.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Заказы"
      Loaded="Page_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView x:Name="OrdersListView" HorizontalContentAlignment="Stretch">
            <ListView.ItemTemplate>
                <DataTemplate>

                    <Border BorderBrush="Black"
                    BorderThickness="1"
                    Margin="5"
                    Padding="10">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock Text="{Binding Id, StringFormat=Заказ №{0}}"
                                   FontWeight="Bold"/>

                                <TextBlock Text="{Binding Users.FullName, StringFormat=Пользователь: {0}}"/>

                                <TextBlock Text="{Binding Date, StringFormat=Дата: {0:dd.MM.yyyy}}"/>

                                <TextBlock Text="{Binding Adress, StringFormat=Адрес: {0}}"/>

                            </StackPanel>

                            <Border Grid.Column="1"
                            BorderBrush="Black"
                            BorderThickness="1"
                            Padding="5"
                            Margin="5">

                                <StackPanel>
                                    <TextBlock Text="Заказ"/>
                                    <TextBlock Text="{Binding Date, StringFormat={}{0:HH:mm}}"
                                       HorizontalAlignment="Center"/>
                                </StackPanel>

                            </Border>

                        </Grid>
                    </Border>

                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="5"
                    x:Name="AdminPanel">

            <Button Content="Удалить заказ"
                    Margin="5"
                    Click="DeleteOrder_Click"/>

        </StackPanel>

    </Grid>
</Page>