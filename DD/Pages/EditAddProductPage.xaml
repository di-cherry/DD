<Page x:Class="DD.Pages.EditAddProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Редактирование продукции">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Width="350">

            <Image Height="120" Width="120" Margin="5">
            <Image.Source>
                <Binding Path="ImagePath">
                    <Binding.TargetNullValue>
                        <BitmapImage UriSource="\Resourse\images.jpg"/>
                    </Binding.TargetNullValue>
                </Binding>
            </Image.Source>
        </Image>

        <Button Content="Выбрать фото"
                Margin="5"
                Click="SelectImage_Click"/>

        <TextBlock Text="Название"/>
        <TextBox Text="{Binding Name}"/>

        <TextBlock Text="Категория"/>
            <ComboBox ItemsSource="{Binding Categories, RelativeSource={RelativeSource AncestorType=Page}}"
          SelectedValue="{Binding CategoryId}"
          SelectedValuePath="Id"
          DisplayMemberPath="Name"/>

            <TextBlock Text="Цена"/>
        <TextBox Text="{Binding Price}"/>

        <TextBlock Text="Количество"/>
        <TextBox Text="{Binding Quantity}"/>

        <TextBlock Text="Описание"/>
        <TextBox Text="{Binding Description}"/>

        <TextBlock Text="Скидка (%)"/>
        <TextBox Text="{Binding Discount}"/>
        
        <Button Content="Сохранить"
                Margin="10"
                Click="Save_Click"/>

    </StackPanel>
    </ScrollViewer>
</Page>
