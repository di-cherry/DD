<Window x:Class="DD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DD"
        mc:Ignorable="d"
        Title="Аптека" Height="450" Width="800">
    <Grid> 
        <Grid.RowDefinitions>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="85*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="/Resourse/аптека.ico" Grid.Column="0"
            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>

            <StackPanel Orientation="Horizontal" Grid.Column="2" Margin="5">

                <TextBlock x:Name="FIOTxtBx" 
                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10"/>

                <Button Content="Назад" HorizontalAlignment="Right"
              VerticalAlignment="Center" Click="Back_Click" Margin="5"/>

                <Button Content="Выйти" VerticalAlignment="Center"
                 HorizontalAlignment="Right" Margin="5" Click="Out_Click"/>

            </StackPanel>
        </Grid>

        <Frame Navigated="MainFrame_Navigated" x:Name="MainFrame" Source="Pages/AuthPage.xaml"
        Grid.Row="1" NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
